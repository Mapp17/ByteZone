<div class="electronics-product-page" style="max-width: 1200px; margin: 0 auto; padding: 20px; font-family: sans-serif;">

  {% comment %} A. PRODUCT BADGES {% endcomment %}
  <div class="product-badges" style="display: flex; gap: 10px; margin-bottom: 15px; font-weight: bold; color: #fff;">
    {% if product.compare_at_price > product.price %}
      {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
      <span style="background: red; padding: 5px 10px; border-radius: 3px;">SALE — Save {{ discount }}%</span>
    {% endif %}
    
    {% if product.tags contains 'new-arrival' %}
      <span style="background: blue; padding: 5px 10px; border-radius: 3px;">New Arrival</span>
    {% endif %}
    
    {% if product.tags contains 'best-seller' %}
      <span style="background: green; padding: 5px 10px; border-radius: 3px;">Best Seller</span>
    {% endif %}
    
    {% unless product.available %}
      <span style="background: grey; padding: 5px 10px; border-radius: 3px;">Sold Out</span>
    {% endunless %}

    {% for tag in product.tags %}
    {% if tag contains 'spec:' %}
        {% assign parts = tag | split: ':' %}
        {% if parts.size >= 3 %}
        {% assign spec_value = parts[2] | strip %}

        {% comment %} High Capacity Check {% endcomment %}
        {% if spec_value contains "1TB" or spec_value contains "2TB" %}
            <span style="background: #5c2d91; color: white; padding: 5px 10px; border-radius: 3px;">High Capacity</span>
        {% endif %}

        {% comment %} Pro Performance Check {% endcomment %}
        {% if spec_value contains "32GB" or spec_value contains "64GB" %}
            <span style="background: #0078d4; color: white; padding: 5px 10px; border-radius: 3px;">Pro Performance</span>
        {% endif %}

        {% comment %} Battery Life Check {% endcomment %}
        {% comment %} Note: We convert to integer for math comparison {% endcomment %}
        {% assign battery_number = spec_value | plus: 0 %}
        {% if battery_number >= 18 %}
            <span style="background: #107c10; color: white; padding: 5px 10px; border-radius: 3px;">All-Day Battery</span>
        {% endif %}

        {% endif %}
    {% endif %}
    {% endfor %}
  </div>

  {% comment %} B. PRODUCT HEADER {% endcomment %}
<header class="product-header" style="margin-bottom: 30px;">
  <h1 style="margin: 0 0 10px 0;">{{ product.title }}</h1>
  <p style="color: #666; margin-bottom: 15px;">{{ product.vendor | upcase }} — {{ product.type }}</p>
  
  <div class="price-display" style="font-size: 1.5rem; margin-bottom: 20px;">
    <span style="color: #d00; font-weight: bold;">{{ product.price | money }}</span>
    {% if product.compare_at_price > product.price %}
      <s style="color: #999; margin-left: 10px;">{{ product.compare_at_price | money }}</s>
    {% endif %}
  </div>
</header>

  {% comment %} B.5 TWO COLUMN LAYOUT - IMAGE AND SPECS SIDE BY SIDE {% endcomment %}
  <div class="image-specs-layout" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px; align-items: start;">
    
    {% comment %} LEFT COLUMN - FEATURED IMAGE {% endcomment %}
    <div class="product-featured-image" style="margin-bottom: 0;">
      <img 
        src="{{ product.featured_image | image_url: width: 800 }}" 
        alt="{{ product.featured_image.alt | default: product.title | escape }}" 
        width="800"
        height="800"
        style="width: 100%; height: auto; border: 1px solid #eee; border-radius: 8px; display: block;"
      >
      <p style="font-size: 0.9rem; color: #888; margin-top: 10px;">Released: {{ product.created_at | date: "%B %d, %Y" }}</p>
    </div>

    {% comment %} RIGHT COLUMN - TECHNICAL SPECIFICATIONS {% endcomment %}
    <div class="specs-sidebar">
      {% if section.settings.show_specs %}
        <section class="specs-section" style="margin-bottom: 40px;">
          <h3 style="border-bottom: 2px solid #333; padding-bottom: 10px; margin-top: 0;">{{ section.settings.specs_heading }}</h3>
          <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
            {% for tag in product.tags %}
              {% if tag contains "spec:" %}
                {% assign parts = tag | split: ":" %}
                {% if parts.size >= 3 %}
                  <tr>
                    <td style="padding: 12px; border-bottom: 1px solid #eee; background: #fafafa; width: 30%;"><strong>{{ parts[1] | strip }}</strong></td>
                    <td style="padding: 12px; border-bottom: 1px solid #eee;">{{ parts[2] | strip }}</td>
                  </tr>
                {% endif %}
              {% endif %}
            {% endfor %}
          </table>
        </section>
      {% endif %}
      
      {% comment %} RENDER ELECTRONICS METAFIELDS HERE {% endcomment %}
      {% render 'electronics-metafields' %}
    </div>
  </div>

  {% comment %} C. PRODUCT DESCRIPTION {% endcomment %}
  <section class="product-description-section" style="margin-bottom: 40px;">
    <div class="description-preview" style="background: #f9f9f9; padding: 20px; border-left: 4px solid #333; margin-bottom: 20px;">
      <strong style="display: block; margin-bottom: 5px;">Quick Summary:</strong>
      <p style="margin: 0; line-height: 1.5;">{{ product.description | strip_html | truncate: 120 }}</p>
    </div>
    
    <div class="full-description" style="line-height: 1.6;">
      {{ product.description }}
    </div>
  </section>



  <hr style="border: 0; border-top: 1px solid #eee; margin: 40px 0;">

  {% comment %} E. VARIANT SELECTOR {% endcomment %}
  <section class="variant-selection" style="margin-bottom: 30px;">
    {% unless product.has_only_default_variant %}
      <h4 style="margin-bottom: 15px;">Available Options</h4>
      <div class="selectors-container" style="display: flex; gap: 20px; flex-wrap: wrap;">
        {% for option in product.options_with_values %}
          <div class="option-group">
            <label style="display: block; font-weight: bold; margin-bottom: 5px;">{{ option.name }}</label>
            <select style="padding: 10px; min-width: 150px; border: 1px solid #ccc; border-radius: 4px;">
              {% for value in option.values %}
                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                  {{ value }}
                </option>
              {% endfor %}
            </select>
          </div>
        {% endfor %}
      </div>
    {% endunless %}
  </section>


  {% comment %} E (Part 2). VARIANT DETAILS TABLE {% endcomment %}
  <section class="variant-inventory" style="margin-bottom: 40px;">
    <h4 style="margin-bottom: 10px;">Configuration Details ({{ product.variants | size }} Total)</h4>
    <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; text-align: left;">
      <thead style="background: #eee;">
        <tr>
          <th style="padding: 10px; border: 1px solid #ddd;">Variant</th>
          <th style="padding: 10px; border: 1px solid #ddd;">SKU</th>
          <th style="padding: 10px; border: 1px solid #ddd;">Price</th>
          <th style="padding: 10px; border: 1px solid #ddd;">Status</th>
        </tr>
      </thead>
      <tbody>
        {% for variant in product.variants %}
          <tr>
            <td style="padding: 10px; border: 1px solid #ddd;">{{ variant.title }}</td>
            <td style="padding: 10px; border: 1px solid #ddd;">{{ variant.sku | default: 'N/A' }}</td>
            <td style="padding: 10px; border: 1px solid #ddd;">{{ variant.price | money }}</td>
            <td style="padding: 10px; border: 1px solid #ddd;">
              {% if variant.available %}<span style="color: green;">In Stock</span>{% else %}<span style="color: red;">Sold Out</span>{% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  {% comment %} F. IMAGE GALLERY {% endcomment %}
  <section class="gallery-section">
    <h4 style="margin-bottom: 15px;">Image Gallery</h4>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px;">
      {% for image in product.images %}
        <div class="gallery-item">
          <a href="{{ image | image_url: width: 2000 }}" target="_blank">
            <img 
              src="{{ image | image_url: width: 400, height: 400, crop: 'center' }}" 
              alt="{{ image.alt | default: product.title | escape }}"
              loading="lazy"
              width="200"
              height="200"
              style="width: 100%; height: auto; border-radius: 6px; border: 1px solid #ddd; transition: transform 0.2s;"
              onmouseover="this.style.transform='scale(1.02)'"
              onmouseout="this.style.transform='scale(1)'"
            >
          </a>
        </div>
      {% endfor %}
    </div>
  </section>

  {% comment %} G. ADD TO CART FORM {% endcomment %}
  <section class="purchase-actions" style="margin-bottom: 40px;">
    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      <button type="submit" name="add"
        {% unless product.available %}disabled{% endunless %} 
        style="width: 100%; max-width: 400px; padding: 18px; font-size: 1.1rem; font-weight: bold; cursor: pointer; border: none; border-radius: 4px;
               background: {% if product.available %}#000{% else %}#ccc{% endif %}; color: #fff;">
        {% if product.available %}
          Add to Cart — {{ product.selected_or_first_available_variant.price | money }}
        {% else %}
          Sold Out
        {% endif %}
      </button>
    {% endform %}
  </section>

  {% comment %} Calculate Min and Max prices in all variants {% endcomment %}
    {% assign min_price = product.variants[0].price %}
    {% assign max_price = product.variants[0].price %}

    {% for variant in product.variants %}
    {% if variant.price < min_price %}
        {% assign min_price = variant.price %}
    {% endif %}
    {% if variant.price > max_price %}
        {% assign max_price = variant.price %}
    {% endif %}
    {% endfor %}

    <div class="price-display" style="font-size: 1.5rem; margin-bottom: 20px; font-weight: bold;">
    {% if min_price == max_price %}
        {% comment %} All variants are the same price {% endcomment %}
        <span style="color: #000;">{{ min_price | money }}</span>
    {% else %}
        {% comment %} Price varies across configurations {% endcomment %}
        <span style="color: #000;">From {{ min_price | money }} — {{ max_price | money }}</span>
    {% endif %}
    
    {% if product.compare_at_price > product.price %}
        <s style="color: #999; margin-left: 10px; font-weight: normal;">{{ product.compare_at_price | money }}</s>
    {% endif %}
    </div>


    
</div>

{% schema %}
{
  "name": "Electronics Product",
  "settings": [
    { "type": "checkbox", "id": "show_specs", "label": "Show specifications table", "default": true },
    { "type": "text", "id": "specs_heading", "label": "Specs section heading", "default": "Technical Specifications" }
  ],
  "presets": [{ "name": "Electronics Product Display" }]
}
{% endschema %}