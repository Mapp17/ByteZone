{{ 'promo-custom.css' | asset_url | stylesheet_tag }}

{%- comment -%} Performance: Defer heavy JS to prevent render-blocking {%- endcomment -%}
<script src="{{ 'heavy-lib.js' | asset_url }}" defer></script>

<section class="promo-section">
  <h2 class="promo-title">{{ section.settings.title | escape }}</h2>
  <p class="promo-body">{{ section.settings.description | escape }}</p>

  {%- if section.settings.hero_image != blank -%}
    <img 
    srcset="{{ section.settings.hero_image | img_url: '400x' }} 400w,
            {{ section.settings.hero_image | img_url: '800x' }} 800w,
            {{ section.settings.hero_image | img_url: '1200x' }} 1200w"
    sizes="(max-width: 400px) 400px, (max-width: 800px) 800px, 1200px"
      src="{{ section.settings.hero_image | img_url: '1200x' }}" 
    alt="{{ section.settings.hero_image.alt | escape }}"
      loading="eager"
      width="1200"
      height="600"
    >
  {%- endif -%}
  {%- comment -%} Accessibility: Added aria-label to the icon-only button {%- endcomment -%}
  <button class="promo-btn" onclick="doPromo()" aria-label="Activate promotional offer">
    Claim Offer
  </button>

  {%- comment -%} SEO: Replaced "click here" with descriptive text {%- endcomment -%}
  <a href="{{ section.settings.link }}" class="promo-link">
    Explore the {{ section.settings.title | escape }} Collection
  </a>

  <form class="promo-subscription">
    <label for="PromoEmail-{{ section.id }}">Subscribe to our newsletter</label>
    <input 
      type="email" 
      id="PromoEmail-{{ section.id }}" 
      placeholder="email@example.com" 
      required
    >
    <button type="submit">Subscribe Now</button>
  </form>

  <div class="promo-grid">
    {% for block in section.blocks %}
      <div class="promo-card" {{ block.shopify_attributes }}>
        {%- if block.settings.card_image != blank -%}
          <img 
            src="{{ block.settings.card_image | img_url: '400x600', crop: 'center' }}"
            alt="{{ block.settings.card_image.alt | default: block.settings.card_title | escape }}"
            loading="lazy"
            width="400"
            height="600"
          >
        {%- endif -%}

        <h3>{{ block.settings.card_title | escape }}</h3>
        <p>{{ block.settings.card_text | escape }}</p>

        <button class="promo-btn" aria-label="View details for {{ block.settings.card_title | escape }}">
          <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M8 0l8 16H0z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  /**
   * Error Handling: Removed undefinedFunction() to prevent console errors.
   * Logic wrapped in a check to ensure heavy-lib is ready if needed.
   */
  function doPromo() {
    console.log("Promo action initiated.");
    // Securely check for external library dependencies
    if (window.__heavyLibLoaded) {
       // Proceed with library-dependent logic
    }
  }
</script>

{% schema %}
{
  "name": "Promo Section (Optimized)",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Big Sale Today" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Check out our latest deals." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "url", "id": "link", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Card Image" },
        { "type": "text", "id": "card_title", "label": "Card Title", "default": "Product Name" },
        { "type": "text", "id": "card_text", "label": "Card Text", "default": "Short description here." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Promo Section" }]
}
{% endschema %}