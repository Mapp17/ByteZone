<script src="{{ 'heavy-lib.js' | asset_url }}" defer></script>

<style>
  .promo-section {
    background: #f0f0f0;
    padding: 40px 20px;
  }
  .promo-title {
    font-size: 2rem;
    color: #ccc;
  }
  .promo-body {
    font-size: 1rem;
    color: #ddd;
  }
  .promo-btn {
    background: #e0e0e0;
    color: #fff;
    padding: 12px 24px;
    border: none;
    cursor: pointer;
  }
  .promo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .promo-card {
    background: #fff;
    border-radius: 8px;
    padding: 16px;
  }
</style>

<section class="promo-section">
  <h2 class="promo-title">{{ section.settings.title }}</h2>

  <p class="promo-body">{{ section.settings.description }}</p>

  <img src="{{ section.settings.hero_image | img_url: '1200x' }}">

  <button class="promo-btn" onclick="doPromo()"></button>

  <a href="{{ section.settings.link }}">click here</a>

  <form>
    <input type="email" placeholder="Enter your email">
    <button type="submit">Subscribe</button>
  </form>

  <div class="promo-grid">
    {% for block in section.blocks %}
      <div class="promo-card" {{ block.shopify_attributes }}>
        <img src="{{ block.settings.card_image | img_url: '400x' }}">

        <h3>{{ block.settings.card_title }}</h3>
        <p>{{ block.settings.card_text }}</p>

        <button class="promo-btn">
          <svg width="16" height="16" viewBox="0 0 16 16">
            <path d="M8 0l8 16H0z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  function doPromo() {
    undefinedFunction();
  }
  doPromo();
</script>

{% schema %}
{
  "name": "Promo Section (Broken)",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Big Sale Today" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Check out our latest deals." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero Image" },
    { "type": "url", "id": "link", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Card Image" },
        { "type": "text", "id": "card_title", "label": "Card Title", "default": "Product Name" },
        { "type": "text", "id": "card_text", "label": "Card Text", "default": "Short description here." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Promo Section" }]
}
{% endschema %}
