<div class="featured-collections">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.subheading }}</p>
  <div class="collections-grid">
    {% for block in section.blocks %}
      <div class="collection-card" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.collection.url }}">
          <img src="{{ block.settings.collection.image | image_url: width: 600 }}" 
                alt="{{ block.settings.collection.title }}"
                width="300"
                height="300"
         />
          <h3>{{ block.settings.collection.title }}</h3>
          <p>{{ block.settings.collection.products_count }} products</p>
          <button>{{ block.settings.button_text }}</button>
        </a>
      </div>
    {% endfor %}
  </div>
</div>

<style>
.featured-collections {
  text-align: center;
}

.collections-grid {
  display: grid;
  gap: 20px;
}

@media (max-width: 599px) {
  .collections-grid {
    grid-template-columns: 1fr;
  }
}

@media (min-width: 600px) and (max-width: 899px) {
  .collections-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 900px) {
  .collections-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.collection-card {
  border: 1px solid #ddd;
  padding: 10px;
  text-align: left;
}

.collection-card img {
  width: 100%;
  height: auto;
}

.collection-card h3 {
  margin: 10px 0;
}

.collection-card button {
  background: #000;
  color: #fff;
  border: none;
  padding: 10px;
  cursor: pointer;
}
</style>

{% schema %}
{
  "name": "Featured Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our collections"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections Grid",
      "category": "Homepage"
    }
  ]
}
{% endschema %}